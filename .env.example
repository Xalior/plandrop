# Copy to .env and adjust. Used by docker-compose.yml.

# Host path to the runtime data root. Holds hosts/ (per-tenant content) and
# auth/ (the shared htpasswd). Git-ignored runtime state — never committed.
PLANDROP_DATA=./data

# Loopback host port mapped to Apache's in-container port 80 (plain HTTP;
# TLS/ingress terminate in front).
PLANDROP_APACHE_PORT=8088

# Ownership of the data tree, shared between Apache and the Phase 3 control
# plane (the privileged writer of hosts/ and auth/). Set to the owner that
# both containers should read/write as. Apache itself starts as root and drops
# to the daemon user to bind port 80; these govern host-side file ownership.
PLANDROP_UID=1000
PLANDROP_GID=1000
