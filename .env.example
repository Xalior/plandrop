# Copy to .env and adjust. Used by docker-compose.yml.

# Host address the services bind on. 127.0.0.1 for local dev; in a deployment,
# the address a front proxy reaches them on (e.g. the docker-bridge gateway
# 172.17.0.1, or a tailnet IP). TLS/ingress terminate in front.
PLANDROP_BIND=127.0.0.1

# Host path to the runtime data root. Holds hosts/ (per-tenant content) and
# auth/ (the shared htpasswd). Git-ignored runtime state — never committed.
PLANDROP_DATA=./data

# The plain-HTTP port Apache listens on, in-container and on the host loopback
# (mapped 1:1). Unprivileged so the container can run as a non-root user; TLS
# and ingress terminate in front of it.
PLANDROP_APACHE_PORT=8080

# The plain-HTTP port the control plane listens on (mapped 1:1). The reverse
# proxy routes the parent domain here and *.domain to Apache.
PLANDROP_CONTROL_PORT=8081

# Ownership the containers run as, and that the data tree should be owned by on
# the host. Shared between Apache and the Phase 3 control plane (the privileged
# writer of hosts/ and auth/). DAV writes land as this UID.
PLANDROP_UID=1000
PLANDROP_GID=1000
