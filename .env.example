# Copy to .env and adjust. Used by docker-compose.yml.

# Host address the services bind on. 127.0.0.1 for local dev; in a deployment,
# the address a front proxy reaches them on (e.g. the docker-bridge gateway
# 172.17.0.1, or a tailnet IP). TLS/ingress terminate in front.
PLANDROP_BIND=127.0.0.1

# Host path to the runtime data root. Holds hosts/ (per-tenant content) and
# auth/ (the shared htpasswd). Git-ignored runtime state — never committed.
PLANDROP_DATA=./data

# What the `default` template alias resolves to (must name an available
# template; an unknown value falls back to bootstrap5). Unset = bootstrap5. The
# control plane reports it as `default` in /api/templates, and the ingress seed
# mirrors that theme's folder to .plandrop/default/ as the autoindex chrome.
# Changing it is a reboot (the re-seed re-copies default/).
# PLANDROP_DEFAULT_TEMPLATE=bootstrap5

# Host path to operator drop-in templates, bind-mounted read-only into the
# ingress (served at /.plandrop/user/), Apache (served per-tenant), and the
# control plane (enumerated as user/<name>). A SEPARATE mount from the seeded
# built-in volume, so a fresh seed never wipes it. Each subfolder is a template
# (needs at least a template.html; header/footer/assets as it likes).
PLANDROP_USER_TEMPLATES=./user-templates

# The plain-HTTP port Apache listens on, in-container and on the host loopback
# (mapped 1:1). Unprivileged so the container can run as a non-root user; TLS
# and ingress terminate in front of it.
PLANDROP_APACHE_PORT=8080

# The plain-HTTP port the ingress listens on, in-container and on the host
# (mapped 1:1). The CLI's bare parent domain routes here (template statics +
# /api proxy); a front proxy routes *.domain to Apache.
PLANDROP_INGRESS_PORT=8082

# --- Dev/test front proxy (the `testproxy` compose profile only) -------------
# Production puts a real external front proxy (NPM/Cloudflare/etc.) in front and
# never starts this service. For local manual + automated testing, the `proxy`
# service stands in for it: it routes by Host on a single port — the bare
# PLANDROP_PROXY_DOMAIN to the ingress, *.<domain> to Apache — so a browser and
# the CLI share ONE domain. Start it with: docker compose --profile testproxy up
PLANDROP_PROXY_PORT=8083
PLANDROP_PROXY_DOMAIN=localhost
# Address the proxy port binds on (defaults to PLANDROP_BIND). Set to ::1 if your
# tenant hosts (e.g. *.localhost) resolve to IPv6 loopback.
# PLANDROP_PROXY_BIND=127.0.0.1

# Ownership the containers run as, and that the data tree should be owned by on
# the host. Shared between Apache and the Phase 3 control plane (the privileged
# writer of hosts/ and auth/). DAV writes land as this UID.
PLANDROP_UID=1000
PLANDROP_GID=1000

# Docker Compose project name — the prefix for containers/networks/volumes
# (e.g. plandrop-apache-1). The compose file defaults this to "plandrop";
# uncomment to override.
# COMPOSE_PROJECT_NAME=plandrop
