node_modules/
dist/
plandrop-*.tgz
*.log

# Local env + runtime data (per-tenant content, shared htpasswd) — never committed.
.env
/data/

# Generated template themes — built from the bootstrap5 skeleton at image-build
# time (and by the generator locally). Only the skeleton and the shared,
# theme-neutral assets (enhance.js, selfupdate.js, plandrop.css) are tracked;
# the shared vendor bundles (mermaid, highlight.js) are copied from the pinned
# npm packages by the same generator run.
templates/*/
!templates/bootstrap5/
!templates/shared/
templates/shared/vendor/
