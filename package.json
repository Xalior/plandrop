{
  "name": "plandrop",
  "version": "0.0.1",
  "description": "Push a static HTML document to a unique, secure hostname on your network and share the link.",
  "type": "module",
  "license": "LGPL-3.0-only",
  "packageManager": "pnpm@10.18.1",
  "bin": {
    "plandrop": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "gen:templates": "node scripts/gen-templates.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "bootswatch": "5.3.8",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.26",
    "webdav": "^5.10.0"
  }
}
